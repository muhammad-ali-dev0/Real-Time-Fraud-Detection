# ── Producer ──────────────────────────────────────────────────────────────────
TRANSACTIONS_PER_SECOND=100
FRAUD_RATE=0.02

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_INPUT_TOPIC=transactions
KAFKA_ALERT_TOPIC=fraud-alerts

# ── Spark ─────────────────────────────────────────────────────────────────────
FRAUD_THRESHOLD=0.65
CHECKPOINT_DIR=/tmp/spark-checkpoints
METRICS_PORT=8000

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Benchmark ─────────────────────────────────────────────────────────────────
BENCHMARK_PROBES=200
BENCHMARK_TIMEOUT=30
